# ContainerEnv detection
# ---------------------------------------------------------------------------

class ContainerEnv:
    """Detect Podman and cgroup version."""

    def __init__(self) -> None:
        self.has_cgroups2: bool = False
        self.ok: bool = True
        self.container_bin: Optional[str] = None
        self.failure: Optional[str] = None

        self.container_bin = shutil.which("podman")
        if not self.container_bin:
            self.failure = "UNKNOWN - Podman not installed"
            self.ok = False
            return

        # Check cgroup version
        try:
            import yaml
            cmd = [self.container_bin, "info"]
            info = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, encoding="utf-8")
            if info.returncode == 0:
                yaml_data = yaml.safe_load(info.stdout)
                try:
                    self.has_cgroups2 = yaml_data["host"]["cgroupVersion"] == "v2"
                except (KeyError, TypeError):
                    self.has_cgroups2 = False
        except ImportError:
            # pyyaml not available — try heuristic
            self.has_cgroups2 = os.path.exists("/sys/fs/cgroup/cgroup.controllers")


# ---------------------------------------------------------------------------
# Main execution flow
# ---------------------------------------------------------------------------

def build_argument_parser() -> ArgumentParser:
    """Build CLI argument parser with all 26+ arguments from data-model.md."""
    parser = ArgumentParser(description="CEP - Containerized E2E Playwright monitoring plugin")

    # Required arguments
    parser.add_argument("--host-name", required=True, dest="host_name",
                        help="Naemon $HOSTNAME$ macro")
    parser.add_argument("--service-description", required=True, dest="service_description",
                        help="Naemon $SERVICEDESC$ macro")
    parser.add_argument("--image", required=True,
                        help="Podman image name with tag")
    parser.add_argument("--probe-location", required=True, dest="probe_location",
                        help="Geographic location identifier")

    # Plugin selectors
    parser.add_argument("--test-source", default="local", dest="test_source",
                        choices=["local", "s3"],
                        help="Test acquisition plugin (default: local)")
    parser.add_argument("--result-dest", default="local", dest="result_dest",
                        choices=["local", "s3"],
                        help="Result delivery plugin (default: local)")
    parser.add_argument("--logging", default="none",
                        choices=["none", "loki"],
                        help="Log shipping backend (default: none)")

    # Path arguments
    omd_root = os.environ.get("OMD_ROOT", "")
    parser.add_argument("--test-dir", dest="test_dir",
                        default=omd_root + "/etc/check_cep/tests/%h/%s",
                        help="Host-side test scripts directory (supports %%h, %%s)")
    parser.add_argument("--result-dir", dest="result_dir",
                        default=omd_root + "/var/tmp/check_cep/%h/%s",
                        help="Host-side results directory (supports %%h, %%s)")
    parser.add_argument("--testscripts-cache", dest="testscripts_cache",
                        default=omd_root + "/var/tmp/testscripts_cache",
                        help="Cache directory for S3 test scripts")

    # Execution settings
    parser.add_argument("--timeout", type=int, default=60,
                        help="Container timeout in seconds (default: 60)")
    parser.add_argument("--memory-limit", dest="memory_limit", default=DEFAULT_MEMORY_LIMIT,
                        help="Container memory limit (default: 2g)")

    # Debug/shell
    parser.add_argument("--debug", action="store_true", default=False,
                        help="Enable verbose logging")
    parser.add_argument("--shell", action="store_true", default=False,
                        help="Start container with bash instead of run.py")

    # Report URL
    parser.add_argument("--report-url", dest="report_url", default=None,
                        help="URL template for HTML report link")
    parser.add_argument("--href-target", dest="href_target", default="_blank",
                        help="HTML target for report link (default: _blank)")

    # Registry auth
    parser.add_argument("--registry-username", dest="registry_username", default=None)
    parser.add_argument("--registry-password", dest="registry_password", default=None)

    # S3 arguments
    parser.add_argument("--s3-endpoint", dest="s3_endpoint", default=None)
    parser.add_argument("--aws-access-key-id", dest="aws_access_key_id", default=None)
    parser.add_argument("--aws-secret-access-key", dest="aws_secret_access_key", default=None)
    parser.add_argument("--s3-bucket", dest="s3_bucket", default=None)
    parser.add_argument("--s3-report-bucket", dest="s3_report_bucket", default=None)
    parser.add_argument("--s3-report-path", dest="s3_report_path", default=None)
    parser.add_argument("--s3-report-url", dest="s3_report_url", default=None)

    # Loki arguments
    parser.add_argument("--loki-endpoint", dest="loki_endpoint", default=None)
    parser.add_argument("--loki-user", dest="loki_user", default=None)
    parser.add_argument("--loki-password", dest="loki_password", default=None)
    parser.add_argument("--loki-proxy", dest="loki_proxy", default=None)

    # Naemon state
    parser.add_argument("--current-status", dest="current_status", default=None,
                        help="$SERVICESTATE$/$SERVICESTATETYPE$/...")

    return parser


def main() -> int:
    """Main entry point."""
    parser = build_argument_parser()
    args = parser.parse_args()

    # ---------------------------------------------------------------------------
    # Logging setup (T032)
    # ---------------------------------------------------------------------------
    omd_root = os.environ.get("OMD_ROOT", "")
    log_path = omd_root + "/var/log/check_cep.log"

    logger.setLevel(logging.DEBUG if args.debug else logging.CRITICAL)
    try:
        file_handler = RotatingFileHandler(log_path, maxBytes=LOG_MAX_BYTES, backupCount=LOG_BACKUP_COUNT)
        formatter = logging.Formatter("%(asctime)s - %(levelname)s - %(message)s")
        file_handler.setFormatter(formatter)
        file_handler.setLevel(logging.DEBUG if args.debug else logging.CRITICAL)
        logger.addHandler(file_handler)
    except (OSError, IOError):
        pass  # Log dir may not exist outside OMD

    if args.debug:
        console_handler = logging.StreamHandler()
        console_handler.setFormatter(logging.Formatter("%(asctime)s - %(levelname)s - %(message)s"))
        console_handler.setLevel(logging.DEBUG)
        logger.addHandler(console_handler)

    # ---------------------------------------------------------------------------
    # Detect container environment
    # ---------------------------------------------------------------------------
    containerenv = ContainerEnv()
    if not containerenv.ok:
        return nagios_exit("UNKNOWN", containerenv.failure)

    # ---------------------------------------------------------------------------
    # Derive names and paths
    # ---------------------------------------------------------------------------
    hostname = args.host_name
    servicedescription = args.service_description
    testname = derive_testname(hostname, servicedescription)
    testident = derive_testident(hostname, servicedescription)
    container_name = sanitize_container_name(testname)
    result_dir = resolve_path_template(args.result_dir, hostname, servicedescription)

    # ---------------------------------------------------------------------------
    # PID file concurrency check (T015)
    # ---------------------------------------------------------------------------
    if args.result_dest == "local":
        os.makedirs(result_dir, mode=PERM_WORLD_RWX, exist_ok=True)
        os.chmod(result_dir, PERM_WORLD_RWX)

    pid_file = os.path.join(result_dir, f"running_{testident}")
    existing_pid = check_pid_file(pid_file)
    if existing_pid is not None:
        return nagios_exit("UNKNOWN", f"test {servicedescription} duplicate, "
                          f"process with PID {existing_pid} is already running")

    write_pid_file(pid_file)

    # ---------------------------------------------------------------------------
    # Container cleanup (T016)
    # ---------------------------------------------------------------------------
    container_cleanup(containerenv.container_bin, container_name)

    # ---------------------------------------------------------------------------
    # Build and execute container (T007, T008, T017)
    # ---------------------------------------------------------------------------
    start_time = time.time()
    env_vars = build_env_vars(args)
    cmd = build_podman_command(containerenv.container_bin, container_name, args, env_vars)

    # Start cgroup poller (T027)
    cgroup_poller = None
    if containerenv.has_cgroups2:
        cgroup_poller = CgroupPoller(container_name, DEFAULT_CPU_COUNT)
        cgroup_poller.start()

    stdout, stderr, returncode = execute_container(cmd, shell_mode=args.shell)

    # Stop cgroup poller
    if cgroup_poller:
        cgroup_poller.stop()

    wall_duration = int(time.time() - start_time)

    # Cleanup PID file
    remove_pid_file(pid_file)

    # Shell mode: just exit
    if args.shell:
        return returncode

    # ---------------------------------------------------------------------------
    # Auth retry (T018)
    # ---------------------------------------------------------------------------
    if (returncode == EXIT_AUTH_REQUIRED
            and b"Authentication is required" in stderr
            and args.registry_username):
        stdout, stderr, returncode = retry_with_auth(
            containerenv.container_bin, cmd, args.image,
            args.registry_username, args.registry_password)
    elif returncode == EXIT_AUTH_REQUIRED:
        returncode = EXIT_CRITICAL

    # ---------------------------------------------------------------------------
    # Sanitize container output (T034)
    # ---------------------------------------------------------------------------
    stdout_str = sanitize_output(stdout)
    stderr_str = sanitize_output(stderr)

    # ---------------------------------------------------------------------------
    # Parse steps.json (T019)
    # ---------------------------------------------------------------------------
    perfdata = []
    container_output = ""
    has_stderr_in_steps = False

    if args.result_dest == "local":
        steps_json_path = os.path.join(result_dir, "steps.json")
        steps_data = parse_steps_json(steps_json_path)
    else:
        # For S3 mode, steps.json is not on host — use stdout as container output
        steps_data = None

    if steps_data is not None:
        perfdata.extend(extract_perfdata_from_steps(steps_data))
        perfdata.extend(extract_nagios_perfdata_from_stdout(steps_data))
        container_output, has_stderr_in_steps = extract_output_from_steps(steps_data)
    else:
        container_output = stdout_str
        if stderr_str:
            container_output += "\n" + stderr_str

    container_output = container_output.strip()
    if not container_output:
        container_output = "NO CONTAINER OUTPUT"

    # Extract Loki errors from stdout
    loki_errors = re.findall(r"LOKIERROR \[\[\[(.*?)\]\]\]", stdout_str)
    for loki_err in loki_errors:
        container_output += "\n" + loki_err

    # ---------------------------------------------------------------------------
    # Add wall-clock duration perfdata
    # ---------------------------------------------------------------------------
    perfdata.append({"label": "duration", "value": wall_duration, "unit": "s"})

    # ---------------------------------------------------------------------------
    # Add cgroup metrics perfdata (T030)
    # ---------------------------------------------------------------------------
    oom_killed = False
    if cgroup_poller:
        metrics = cgroup_poller.get_metrics()
        perfdata.append({"label": "podman_metric_collection_failed", "value": 1 if metrics["collection_failed"] else 0})

        if metrics["sample_count"] > 0:
            perfdata.append({"label": "podman_cpu_usage", "value": f"{metrics['cpu_usage_sec']:.2f}", "unit": "s"})
            perfdata.append({"label": "podman_peak_cpu", "value": f"{metrics['peak_cpu_pct']:.1f}", "unit": "%"})
            perfdata.append({"label": "podman_memory_current", "value": metrics["memory_current"], "unit": "B"})
            perfdata.append({"label": "podman_memory_peak", "value": metrics["memory_peak"], "unit": "B"})
            perfdata.append({"label": "podman_io_bytes_read", "value": metrics["io_bytes_read"], "unit": "B"})
            perfdata.append({"label": "podman_io_bytes_write", "value": metrics["io_bytes_write"], "unit": "B"})

            oom_kill_val = 1 if metrics["oom_kill"] > 0 else 0
            perfdata.append({"label": "podman_oom_killed", "value": oom_kill_val})
            if oom_kill_val:
                oom_killed = True
                container_output = "OOM_KILLED: container was terminated by out-of-memory killer"

        if metrics["collection_failed"]:
            errors = metrics.get("collection_errors", [])
            if errors:
                container_output += "\ncgroup metrics: " + "; ".join(errors)

    # ---------------------------------------------------------------------------
    # Normalize and format perfdata
    # ---------------------------------------------------------------------------
    perfdata = normalize_perfdata_labels(perfdata)
    perfdata_str = format_perfdata(perfdata)

    # ---------------------------------------------------------------------------
    # Exit code determination chain (T020)
    # ---------------------------------------------------------------------------
    timed_out = check_timeout(stdout_str, stderr_str)
    s3_failed = check_s3_upload_failure(stdout_str, stderr_str)
    duplicate = check_duplicate_container(stderr_str)

    # Read test-meta.json for timestamp (for report URL)
    test_meta = {}
    if args.result_dest == "local":
        meta_path = os.path.join(result_dir, "test-meta.json")
        if os.path.exists(meta_path):
            try:
                with open(meta_path, "r") as f:
                    test_meta = json.load(f)
            except (json.JSONDecodeError, IOError):
                pass

    # Build report annotation (T024)
    annotation = ""
    if args.report_url:
        timestamp = test_meta.get("timestamp", str(int(time.time())))
        resolved_url = resolve_report_url(
            args.report_url, hostname, servicedescription, testident,
            args.probe_location, args.s3_report_bucket or "", timestamp)
        annotation = f' <a href="{urllib.parse.quote(resolved_url, safe=":/?&=")}" target="{args.href_target}">Report</a>'

    # Exit code priority chain (T020, T031)
    if oom_killed:
        exit_code = nagios_exit("CRITICAL", f"test {servicedescription} OOM killed{annotation}",
                               perfdata_str, container_output)
    elif timed_out:
        exit_code = nagios_exit("CRITICAL", f"test {servicedescription} timed out{annotation}",
                               perfdata_str, container_output)
    elif returncode != 0 and not duplicate:
        exit_code = nagios_exit("CRITICAL", f"test {servicedescription} failed{annotation}",
                               perfdata_str, container_output)
    elif has_stderr_in_steps and returncode == 0:
        exit_code = nagios_exit("WARNING", f"test {servicedescription} succeeded{annotation}",
                               perfdata_str, container_output)
    elif duplicate:
        exit_code = nagios_exit("UNKNOWN",
                               f"test {servicedescription} duplicate{annotation}, running on host {os.uname()[1]}",
                               perfdata_str, container_output)
    else:
        exit_code = nagios_exit("OK", f"test {servicedescription} succeeded{annotation}",
                               perfdata_str, container_output)

    # S3 failure appended as warning text (doesn't change exit code)
    if s3_failed:
        print("REPORT UPLOAD TO S3 FAILED")

    return exit_code


if __name__ == "__main__":
    sys.exit(main())
