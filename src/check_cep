CGROUP_BASE_PATH = "/sys/fs/cgroup"


# ---------------------------------------------------------------------------
# Output sanitization utilities
# ---------------------------------------------------------------------------

def remove_html_entities(line: str) -> str:
    """Escape HTML special characters for safe Nagios output."""
    return (
        line.replace("&", "&amp;")
        .replace("<", "&lt;")
        .replace(">", "&gt;")
        .replace('"', "&quot;")
    )


def remove_ansi_escapes(line: bytes) -> str:
    """Remove ANSI escape codes from byte string, decode to ASCII."""
    ansi_escape = re.compile(r"(?:\x1B[@-_]|[\x80-\x9F])[0-?]*[ -/]*[@-~]")
    decoded = line.decode("ascii", "ignore")
    cleaned = ansi_escape.sub("", decoded)
    cleaned = re.sub(r"(?imu)^\s*\n", "", cleaned)
    return cleaned.replace("|", "")


def remove_invalid_surrogates(text: str) -> str:
    """Remove invalid Unicode surrogates."""
    return "".join(char for char in text if unicodedata.category(char) != "Cn")


def remove_variation_selectors(text: str) -> str:
    """Remove invisible variation selectors (U+FE0E, U+FE0F)."""
    return re.sub(r"[\uFE0E\uFE0F]", "", text)


def replace_emojis(line: str) -> str:
    """Replace emoji characters with ASCII equivalents."""
    emoji_replacements = {
        "\U0001f602": ":-D",
        "\U0001f60a": ":-)",
        "\U0001f622": ":'(",
        "\U0001f60e": "B-)",
        "\U00002764": "<3",
        "\U0001f50d": ":emoji:",
    }
    line = unicodedata.normalize("NFC", line)
    line = remove_invalid_surrogates(line)
    line = remove_variation_selectors(line)
    emoji_pattern = re.compile(
        r"[\U0001f600-\U0001f64f\U0001f300-\U0001f5ff"
        r"\U0001f680-\U0001f6ff\U0001f700-\U0001f77f"
        r"\U0001f900-\U0001faff]+",
        flags=re.UNICODE,
    )

    def emoji_replacer(match):
        return emoji_replacements.get(match.group(0), ":emoji:")

    return emoji_pattern.sub(emoji_replacer, line).encode("utf-8", errors="replace").decode("utf-8")


def sanitize_output(raw: bytes) -> str:
    """Full sanitization pipeline for container output."""
    text = remove_ansi_escapes(raw)
    text = replace_emojis(text)
    text = remove_html_entities(text)
    return text


# ---------------------------------------------------------------------------
# Nagios output formatting (T006)
# ---------------------------------------------------------------------------

def camelcase(label: str) -> str:
    """Convert space-separated label to CamelCase."""
    return "".join(word.capitalize() for word in label.strip().split())


def format_perfdata(perfdata_list: List[Dict[str, Any]]) -> str:
    """Format perfdata list as Nagios perfdata string.

    All labels are single-quoted per the Nagios output contract.
    """
    parts = []
    for pd in perfdata_list:
        label = pd["label"]
        value = pd["value"]
        unit = pd.get("unit", "")
        parts.append(f"'{label}'={value}{unit}")
    return " ".join(parts)


def nagios_exit(status: str, message: str, perfdata_str: str = "", long_output: str = "") -> int:
    """Print Nagios status line and return exit code.

    Args:
        status: One of OK, WARNING, CRITICAL, UNKNOWN
        message: Human-readable summary
        perfdata_str: Pre-formatted perfdata string
        long_output: Multi-line details (lines 2+)

    Returns:
        Nagios exit code integer
    """
    code_map = {"OK": EXIT_OK, "WARNING": EXIT_WARNING, "CRITICAL": EXIT_CRITICAL, "UNKNOWN": EXIT_UNKNOWN}
    line1 = f"{status} - {message}"
    if perfdata_str:
        line1 += f" | {perfdata_str}"
    print(line1)
    if long_output:
        print(long_output)
    return code_map.get(status, EXIT_UNKNOWN)


# ---------------------------------------------------------------------------
# TESTNAME derivation and path template resolution (T005)
# ---------------------------------------------------------------------------

def derive_testname(hostname: str, servicedescription: str) -> str:
    """Derive TESTNAME from hostname and service description.

    TESTNAME is symbolic, not a path. Used as container name and PID identity.
    """
    return f"{hostname}/{servicedescription}"


def derive_testident(hostname: str, servicedescription: str) -> str:
    """Derive URL-encoded TESTIDENT for PID files and archive names."""
    return urllib.parse.quote(f"{hostname}__{servicedescription}", safe="")


def resolve_path_template(template: str, hostname: str, servicedescription: str) -> str:
    """Replace %h and %s template variables in path strings."""
    return template.replace("%h", hostname).replace("%s", servicedescription)


def sanitize_container_name(testname: str) -> str:
    """Sanitize testname for use as Podman container name."""
    return re.sub(r"[^a-zA-Z0-9_.-]+", "_", testname.replace(" ", "_"))


# ---------------------------------------------------------------------------
# PID file concurrency control (T015)
# ---------------------------------------------------------------------------

def is_process_running(pid: int) -> bool:
    """Check if a process with given PID is running."""
    try:
        os.kill(pid, 0)
    except OSError:
        return False
    return True


def check_pid_file(pid_file_path: str) -> Optional[int]:
    """Check PID file. Returns existing PID if running, None otherwise."""
    if not os.path.exists(pid_file_path):
        return None
    try:
        with open(pid_file_path, "r") as f:
            existing_pid = int(f.read().strip())
        if is_process_running(existing_pid):
            return existing_pid
        else:
            logger.debug(f"Found stale PID {existing_pid}. Overwriting.")
            return None
    except (ValueError, IOError) as e:
        logger.warning(f"Could not read PID file {pid_file_path}: {e}")
        return None


def write_pid_file(pid_file_path: str) -> None:
    """Write current PID to file."""
    with open(pid_file_path, "w") as f:
        f.write(str(os.getpid()))


def remove_pid_file(pid_file_path: str) -> None:
    """Remove PID file if it exists."""
    try:
        if os.path.exists(pid_file_path):
            os.remove(pid_file_path)
    except OSError as e:
        logger.warning(f"Could not remove PID file {pid_file_path}: {e}")


# ---------------------------------------------------------------------------
# Container cleanup (T016)
# ---------------------------------------------------------------------------

def container_cleanup(container_bin: str, container_name: str) -> None:
    """Remove stale container with same name via podman rm -f."""
    cmd = [container_bin, "rm", "--force", "--filter", f"name=^{container_name}$"]
    subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, encoding="utf-8")


# ---------------------------------------------------------------------------
# Container environment variable assembly (T007)
# ---------------------------------------------------------------------------

def build_env_vars(args) -> Dict[str, str]:
    """Build container environment variable dict from CLI args."""
    env = {
        "TEST_SOURCE": args.test_source,
        "RESULT_DEST": args.result_dest,
        "LOGGING": args.logging,
        "NAGIOS_HOSTNAME": args.host_name,
        "NAGIOS_SERVICEDESC": args.service_description,
        "PWTIMEOUT": str(args.timeout),
        "PROBE_LOCATION": args.probe_location,
        "TESTIDENT": derive_testident(args.host_name, args.service_description),
        "TERM": "dumb",
        "FORCE_COLOR": "false",
    }

    if args.debug:
        env["DEBUG"] = "1"

    # S3 credentials (when S3 plugins active)
    if args.s3_endpoint:
        env["S3_ENDPOINT"] = args.s3_endpoint
    if args.aws_access_key_id:
        env["AWS_ACCESS_KEY_ID"] = args.aws_access_key_id
    if args.aws_secret_access_key:
        env["AWS_SECRET_ACCESS_KEY"] = args.aws_secret_access_key
    if args.s3_bucket:
        env["S3_BUCKET"] = args.s3_bucket
    if args.s3_report_bucket:
        env["S3_REPORT_BUCKET"] = args.s3_report_bucket
    if args.s3_report_path:
        env["REPORT_PATH"] = args.s3_report_path

    # Loki credentials (when logging=loki)
    if args.loki_endpoint:
        env["LOKI_ENDPOINT"] = args.loki_endpoint
    if args.loki_user:
        env["LOKI_USER"] = args.loki_user
    if args.loki_password:
        env["LOKI_PASSWORD"] = args.loki_password
    if args.loki_proxy:
        env["LOKI_PROXY"] = args.loki_proxy

    # Naemon state info
    if args.current_status:
        env["NAGIOS_CURRENT_STATUS"] = args.current_status

    return env


# ---------------------------------------------------------------------------
# Podman command building (T008)
# ---------------------------------------------------------------------------

def build_podman_command(container_bin: str, container_name: str, args, env_vars: Dict[str, str]) -> List[str]:
    """Build complete podman run command."""
    cgroup_parent = container_name.replace("-", "_") + ".slice"

    cmd = [
        container_bin,
        "run",
        "--rm",
        "--interactive",
        "--log-driver=none",
        "--hostname", os.uname().nodename,
        "--name", container_name,
        "--cgroup-parent", cgroup_parent,
    ]

    # Resource limits (FR-006: CPU hardcoded at 2)
    cmd.extend(["--cpus", str(DEFAULT_CPU_COUNT)])
    memory_limit = args.memory_limit if args.memory_limit else DEFAULT_MEMORY_LIMIT
    if memory_limit and memory_limit[-1] not in "bkmg":
        memory_limit += "g"
    cmd.extend(["--memory", memory_limit])

    # Environment variables
    for key, value in env_vars.items():
        cmd.extend(["--env", f"{key}={value}"])

    # Conditional volume mounts
    hostname = args.host_name
    servicedescription = args.service_description
    test_dir = resolve_path_template(args.test_dir, hostname, servicedescription)
    result_dir = resolve_path_template(args.result_dir, hostname, servicedescription)

    if args.test_source == "local":
        cmd.extend(["--volume", f"{os.path.abspath(test_dir)}:/home/pwuser/tests:ro,z"])
    if args.result_dest == "local":
        cmd.extend(["--volume", f"{os.path.abspath(result_dir)}:/home/pwuser/results:rw,z"])
    if args.test_source == "s3":
        cache_dir = args.testscripts_cache
        cmd.extend(["--volume", f"{os.path.abspath(cache_dir)}:/testscripts-cache:rw,z"])

    # Shell mode: replace entrypoint with bash
    if args.shell:
        cmd.extend(["--tty", "--interactive", "--entrypoint", "bash"])

    cmd.append(args.image)
    return cmd


# ---------------------------------------------------------------------------
# Container execution (T017)
# ---------------------------------------------------------------------------

def execute_container(cmd: List[str], shell_mode: bool = False) -> Tuple[bytes, bytes, int]:
    """Execute podman run and return (stdout, stderr, returncode)."""
    logger.debug("running command: %s", " ".join(cmd))
    if shell_mode:
        proc = subprocess.run(cmd)
        return b"", b"", proc.returncode
    else:
        proc = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        return proc.stdout, proc.stderr, proc.returncode


# ---------------------------------------------------------------------------
# Registry auth retry (T018)
# ---------------------------------------------------------------------------

def retry_with_auth(container_bin: str, cmd: List[str], image: str,
                    username: str, password: str) -> Tuple[bytes, bytes, int]:
    """Attempt podman login and retry the container command."""
    if "/" not in image:
        return b"", b"", EXIT_CRITICAL

    registry = image.split("/")[0]
    login_cmd = [container_bin, "login", "-u", username, "-p", password, registry]
    logger.debug("login as %s at registry %s", username, registry)
    login = subprocess.run(login_cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)

    if login.returncode == 0:
        logger.debug("re-running command: %s", " ".join(cmd))
        proc = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        return proc.stdout, proc.stderr, proc.returncode
    else:
        logger.debug("login failed")
        return b"", b"", EXIT_CRITICAL


# ---------------------------------------------------------------------------
# steps.json parsing (T019)
# ---------------------------------------------------------------------------

def parse_steps_json(json_path: str) -> Optional[dict]:
    """Parse steps.json file. Returns parsed dict or None."""
    if not os.path.exists(json_path):
        return None
    try:
        with open(json_path, "r", encoding="utf-8") as f:
            return json.load(f)
    except (json.JSONDecodeError, IOError) as e:
        logger.warning(f"Could not parse {json_path}: {e}")
        return None


def extract_perfdata_from_steps(subjson: dict, level: int = 0, prefix: str = "") -> List[Dict[str, Any]]:
    """Recursively extract perfdata from steps.json structure.

    Returns list of perfdata dicts with label, value, unit.
    """
    perfdata = []

    for suite in subjson.get("suites", []):
        if level == 0 and len(subjson["suites"]) > 1:
            new_prefix = camelcase(os.path.basename(suite["title"]).replace(".test.ts", ""))
        elif level == 0:
            new_prefix = prefix
        else:
            new_prefix = prefix + camelcase(suite["title"])
        perfdata.extend(extract_perfdata_from_steps(suite, level + 1, new_prefix))

    for spec in subjson.get("specs", []):
        new_prefix = prefix + camelcase(spec["title"])
        perfdata.extend(extract_perfdata_from_steps(spec, level + 1, new_prefix))

    for test in subjson.get("tests", []):
        if len(subjson["tests"]) > 1:
            new_prefix = prefix + camelcase(test["projectName"])
        else:
            new_prefix = prefix
        if len(test["results"]) > 0:
            perfdata.extend(extract_perfdata_from_steps(test["results"][0], level + 1, new_prefix))
            if "duration" in test["results"][0]:
                perfdata.append({"label": new_prefix + "_td", "value": test["results"][0]["duration"], "unit": "ms"})

        # Annotation-based perfdata
        for annotation in test.get("annotations", []):
            if "type" in annotation and annotation["type"].startswith("perfdata_"):
                m = re.match(r"([\d]+\.*[\d]*)([a-z%]*)", annotation.get("description", ""))
                if m:
                    suffix = "_cd" if m[2] and m[2].endswith("s") else "_cm"
                    perfdata.append({
                        "label": prefix + camelcase(annotation["type"].replace("perfdata_", "") + suffix),
                        "value": m[1],
                        "unit": m[2],
                    })

    for step in subjson.get("steps", []):
        new_prefix = prefix + camelcase(step["title"])
        perfdata.append({"label": new_prefix + "_sd", "value": step["duration"], "unit": "ms"})
        perfdata.extend(extract_perfdata_from_steps(step, level + 1, new_prefix))

    return perfdata


def extract_output_from_steps(subjson: dict, level: int = 0, prefix: str = "") -> Tuple[str, bool]:
    """Recursively extract stdout/stderr/errors from steps.json.

    Returns (output_text, has_stderr).
    """
    output = ""
    has_stderr = False

    for suite in subjson.get("suites", []):
        if level == 0 and len(subjson["suites"]) > 1:
            new_prefix = os.path.basename(suite["title"]).replace(".test.ts", "")
        elif level == 0:
            new_prefix = prefix
        else:
            new_prefix = prefix + " - " + suite["title"]
        sub_output, sub_stderr = extract_output_from_steps(suite, level + 1, new_prefix)
        output += sub_output
        has_stderr = has_stderr or sub_stderr

    for spec in subjson.get("specs", []):
        sub_output, sub_stderr = extract_output_from_steps(spec, level + 1, prefix + " - " + spec["title"])
        output += sub_output
        has_stderr = has_stderr or sub_stderr

    for test in subjson.get("tests", []):
        if len(subjson["tests"]) > 1:
            new_prefix = prefix + " - " + test["projectName"]
        else:
            new_prefix = prefix
        if len(test["results"]) > 0:
            sub_output, sub_stderr = extract_output_from_steps(test["results"][0], level + 1, new_prefix)
            output += sub_output
            has_stderr = has_stderr or sub_stderr

    for index, stdout_entry in enumerate(subjson.get("stdout", [])):
        if index == 0:
            output += "\n__Stdout " + prefix + "__"
        text = stdout_entry.get("text", "")
        if not text.startswith("NagiosPerfData:"):
            output += "\n" + text.rstrip()

    for index, stderr_entry in enumerate(subjson.get("stderr", [])):
        if index == 0:
            output += "\n__Stderr " + prefix + "__"
        output += "\n" + stderr_entry.get("text", "").rstrip()
        has_stderr = True

    for index, error in enumerate(subjson.get("errors", [])):
        if index == 0:
            output += "\n__Errors " + prefix + "__"
        msg = error.get("message", "")
        output += "\n" + sanitize_output(replace_emojis(msg).encode("utf-8")).rstrip()

    return output, has_stderr


def extract_nagios_perfdata_from_stdout(subjson: dict, level: int = 0) -> List[Dict[str, Any]]:
    """Extract NagiosPerfData: lines from stdout in steps.json."""
    perfdata = []

    for suite in subjson.get("suites", []):
        perfdata.extend(extract_nagios_perfdata_from_stdout(suite, level + 1))
    for spec in subjson.get("specs", []):
        perfdata.extend(extract_nagios_perfdata_from_stdout(spec, level + 1))
    for test in subjson.get("tests", []):
        if len(test.get("results", [])) > 0:
            perfdata.extend(extract_nagios_perfdata_from_stdout(test["results"][0], level + 1))

    for stdout_entry in subjson.get("stdout", []):
        text = stdout_entry.get("text", "")
        m = re.match(r"NagiosPerfData:\s*'(.*?)'=([\d]+\.?[\d]*)([a-z%]*)", text)
        if m:
            perfdata.append({"label": m[1], "value": m[2], "unit": m[3]})

    return perfdata


def normalize_perfdata_labels(perfdata: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    """Normalize perfdata labels: strip suffixes for display."""
    num_tests = sum(1 for pd in perfdata if pd["label"].endswith("_td"))

    if num_tests == 1:
        # Single test: simplify labels
        name_test = None
        for pd in perfdata:
            if pd["label"].endswith("_td"):
                name_test = re.sub(r"_td$", "", pd["label"])
                break
        if name_test:
            result = []
            for pd in perfdata:
                label = pd["label"]
                if label.endswith("_td"):
                    result.append({"label": "TestDuration", "value": pd["value"], "unit": pd.get("unit", "")})
                elif any(label.endswith(s) for s in ["_sd", "_cd", "_cm"]):
                    result.append({"label": label.replace(name_test, ""), "value": pd["value"], "unit": pd.get("unit", "")})
                else:
                    result.append(pd)
            perfdata = result
    else:
        # Multiple tests: expand _td to _test_duration
        perfdata = [
            {"label": re.sub(r"_td$", "_test_duration", pd["label"]), "value": pd["value"], "unit": pd.get("unit", "")}
            if pd["label"].endswith("_td") else pd
            for pd in perfdata
        ]

    # Strip remaining suffixes for final output
    result = []
    for pd in perfdata:
        label = pd["label"]
        for suffix in ["_sd", "_cd", "_cm"]:
            label = re.sub(f"{suffix}$", "", label)
        result.append({"label": label, "value": pd["value"], "unit": pd.get("unit", "")})
    return result


# ---------------------------------------------------------------------------
# Exit code determination (T020)
# ---------------------------------------------------------------------------

def check_timeout(stdout: str, stderr: str) -> bool:
    """Detect timeout from container output.

    Two sources:
    - Playwright's own per-test timeout message (when playwright.config.ts
      timeout fires before the outer coreutils timeout)
    - PWTIMEOUT_EXCEEDED marker printed by run.py when coreutils timeout (124/137)
      kills the Playwright process before it can print its own message
    """
    return bool(
        "PWTIMEOUT_EXCEEDED" in stdout
        or "ran into a timeout after" in stderr
        or re.search(r"Test timeout of \d+ms exceeded", stdout)
        or re.search(r"Timeout \d+ms exceeded", stdout)
    )


def check_s3_upload_failure(stdout: str, stderr: str) -> bool:
    """Detect S3 upload failure from container output."""
    return "S3UPLOADHASFAILED" in stderr or "S3UPLOADHASFAILED" in stdout


def check_duplicate_container(stderr: str) -> bool:
    """Detect duplicate container error."""
    return "Error: creating container storage" in stderr and "is already in use" in stderr


# ---------------------------------------------------------------------------
# Report URL template resolution (T023)
# ---------------------------------------------------------------------------

def resolve_report_url(template: str, hostname: str, servicedescription: str,
                       testident: str, probe_location: str, s3_report_bucket: str,
                       timestamp: str) -> str:
    """Resolve report URL template variables."""
    url = template
    url = url.replace("%h", hostname)
    url = url.replace("%s", servicedescription)
    url = url.replace("%i", testident)
    url = url.replace("%l", probe_location)
    url = url.replace("%b", s3_report_bucket or "")
    url = url.replace("%t", timestamp)
    return url


# ---------------------------------------------------------------------------
# CgroupPoller (T027-T031)
# ---------------------------------------------------------------------------

class CgroupPoller:
    """Polls cgroup v2 files during container execution to collect resource metrics.

    Runs in a daemon thread at CGROUP_POLL_INTERVAL_SEC intervals.
    """

    def __init__(self, container_name: str, cpu_count: int) -> None:
        self._container_name = container_name
        self._cgroup_parent = container_name.replace("-", "_")
        self._cpu_count = cpu_count
        self._scope_path: Optional[str] = None
        self._collection_failed = False
        self._collection_errors: set = set()
        self._samples: List[dict] = []
        self._stop_event = threading.Event()
        self._prev_cpu_usec: Optional[int] = None
        self._prev_time: Optional[float] = None
        self._peak_cpu_pct = 0.0
        self._thread: Optional[threading.Thread] = None

    def start(self) -> None:
        """Spawn the daemon polling thread."""
        self._thread = threading.Thread(target=self._poll_loop, daemon=True)
        self._thread.start()

    def stop(self) -> None:
        """Signal the polling thread to exit and wait for it."""
        self._stop_event.set()
        if self._thread:
            self._thread.join(timeout=2)

    def _poll_loop(self) -> None:
        while not self._stop_event.is_set():
            self._poll_once()
            self._stop_event.wait(CGROUP_POLL_INTERVAL_SEC)
        # Final best-effort sample
        self._poll_once()

    def _find_live_scope(self, scopes: List[str], parent: str) -> Optional[str]:
        """Among multiple scopes, return the one with live PIDs."""
        live = []
        for scope in scopes:
            try:
                with open(os.path.join(parent, scope, "cgroup.procs")) as f:
                    pids = f.read().split()
                if pids:
                    live.append((scope, pids))
            except OSError:
                continue

        if len(live) == 1:
            return live[0][0]
        if len(live) == 0:
            return None

        # Multiple live scopes — use /proc/<pid>/cmdline to find run.py
        for scope, pids in live:
            for pid in pids:
                try:
                    with open(f"/proc/{pid}/cmdline") as f:
                        if "run.py" in f.read():
                            return scope
                except OSError:
                    continue
        return None

    def _discover_scope_path(self) -> Optional[str]:
        """Locate the libpod-*.scope directory under the container's slice."""
        uid = os.getuid()
        parent = (
            f"{CGROUP_BASE_PATH}/user.slice/"
            f"user-{uid}.slice/"
            f"user@{uid}.service/"
            f"{self._cgroup_parent}.slice/"
        )
        try:
            entries = os.listdir(parent)
        except OSError:
            return None

        scopes = sorted(
            e for e in entries
            if e.startswith("libpod-") and not e.startswith("libpod-conmon-") and e.endswith(".scope")
        )

        if len(scopes) == 0:
            return None
        if len(scopes) > 1:
            match = self._find_live_scope(scopes, parent)
            if match is None:
                self._collection_errors.add(f"multiple scopes in {parent}, none with live PIDs: {scopes}")
                return None
            self._scope_path = os.path.join(parent, match)
            return self._scope_path

        self._scope_path = os.path.join(parent, scopes[0])
        return self._scope_path

    def _poll_once(self) -> None:
        if self._scope_path is None:
            if self._discover_scope_path() is None:
                return
        elif not os.path.isdir(self._scope_path):
            return  # cgroup already cleaned up (--rm)

        now = time.time()

        memory_current = self._read_single_int("memory.current")
        memory_peak = self._read_single_int("memory.peak")
        usage_usec = self._read_cpu_stat()
        oom_kill = self._read_memory_events_oom()
        io_bytes_read, io_bytes_write = self._read_io_stat()

        # Per-interval CPU %
        if self._prev_cpu_usec is not None and self._prev_time is not None:
            delta_cpu_sec = (usage_usec - self._prev_cpu_usec) / 1_000_000
            delta_wall_sec = now - self._prev_time
            if delta_wall_sec > 0:
                cpu_pct = min(delta_cpu_sec / (delta_wall_sec * self._cpu_count) * 100, 100.0)
                self._peak_cpu_pct = max(self._peak_cpu_pct, cpu_pct)
        self._prev_cpu_usec = usage_usec
        self._prev_time = now

        self._samples.append({
            "memory_current": memory_current,
            "memory_peak": memory_peak,
            "usage_usec": usage_usec,
            "oom_kill": oom_kill,
            "io_bytes_read": io_bytes_read,
            "io_bytes_write": io_bytes_write,
        })

    def _read_single_int(self, filename: str) -> int:
        try:
            with open(os.path.join(self._scope_path, filename)) as f:
                return int(f.read().strip())
        except (OSError, ValueError) as e:
            self._collection_failed = True
            self._collection_errors.add(str(e))
            return 0

    def _read_cpu_stat(self) -> int:
        try:
            with open(os.path.join(self._scope_path, "cpu.stat")) as f:
                for line in f:
                    if line.startswith("usage_usec"):
                        return int(line.split()[1])
        except (OSError, ValueError) as e:
            self._collection_failed = True
            self._collection_errors.add(str(e))
        return 0

    def _read_memory_events_oom(self) -> int:
        try:
            with open(os.path.join(self._scope_path, "memory.events")) as f:
                for line in f:
                    if line.startswith("oom_kill"):
                        return int(line.split()[1])
        except (OSError, ValueError) as e:
            self._collection_failed = True
            self._collection_errors.add(str(e))
        return 0

    def _read_io_stat(self) -> Tuple[int, int]:
        io_read = 0
        io_write = 0
        try:
            with open(os.path.join(self._scope_path, "io.stat")) as f:
                for line in f:
                    for field in line.split():
                        if field.startswith("rbytes="):
                            io_read += int(field.split("=")[1])
                        elif field.startswith("wbytes="):
                            io_write += int(field.split("=")[1])
        except (OSError, ValueError) as e:
            self._collection_failed = True
            self._collection_errors.add(str(e))
        return io_read, io_write

    def get_metrics(self) -> dict:
        """Return aggregated metrics after polling has stopped."""
        if not self._samples:
            return {
                "sample_count": 0,
                "collection_failed": True,
                "collection_errors": sorted(self._collection_errors),
                "cpu_usage_sec": 0.0,
                "peak_cpu_pct": 0.0,
                "memory_current": 0,
                "memory_peak": 0,
                "io_bytes_read": 0,
                "io_bytes_write": 0,
                "oom_kill": 0,
            }

        last = self._samples[-1]
        peak_mem = max(s["memory_peak"] for s in self._samples)

        return {
            "sample_count": len(self._samples),
            "collection_failed": self._collection_failed,
            "collection_errors": sorted(self._collection_errors),
            "cpu_usage_sec": last["usage_usec"] / 1_000_000,
            "peak_cpu_pct": self._peak_cpu_pct,
            "memory_current": last["memory_current"],
            "memory_peak": peak_mem,
            "io_bytes_read": last["io_bytes_read"],
            "io_bytes_write": last["io_bytes_write"],
            "oom_kill": last["oom_kill"],
        }


