def check_timeout(stdout: str, stderr: str) -> bool:
    """Detect timeout from container output.

    Two sources:
    - Playwright's own per-test timeout message (when playwright.config.ts
      timeout fires before the outer coreutils timeout)
    - PWTIMEOUT_EXCEEDED marker printed by run.py when coreutils timeout (124/137)
      kills the Playwright process before it can print its own message
    """
    return bool(
        "PWTIMEOUT_EXCEEDED" in stdout
        or "ran into a timeout after" in stderr
        or re.search(r"Test timeout of \d+ms exceeded", stdout)
        or re.search(r"Timeout \d+ms exceeded", stdout)
    )


def check_s3_upload_failure(stdout: str, stderr: str) -> bool:
    """Detect S3 upload failure from container output."""
    return "S3UPLOADHASFAILED" in stderr or "S3UPLOADHASFAILED" in stdout


def check_duplicate_container(stderr: str) -> bool:
    """Detect duplicate container error."""
    return "Error: creating container storage" in stderr and "is already in use" in stderr


