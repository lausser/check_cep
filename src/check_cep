def resolve_report_url(template: str, ctx: RunContext,
                       probe_location: str, s3_report_bucket: str,
                       timestamp: str) -> str:
    """Resolve report URL template variables."""
    url = template
    url = url.replace("%h", ctx.hostname)
    url = url.replace("%s", ctx.servicedescription)
    url = url.replace("%i", ctx.testident)
    url = url.replace("%l", probe_location)
    url = url.replace("%b", s3_report_bucket or "")
    url = url.replace("%t", timestamp)
    return url


