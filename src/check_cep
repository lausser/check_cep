@dataclass(frozen=True)
class RunConfig:
    """Typed, immutable representation of all CLI arguments.

    Constructed once from argparse.Namespace immediately after argument
    parsing. Every field has a name and type — no raw namespace access
    after construction.
    """
    # Identity (required)
    host_name: str
    service_description: str
    image: str
    probe_location: str

    # Plugin selectors
    test_source: str
    result_dest: str
    logging: str

    # Paths (templates — not yet expanded)
    test_dir: str
    result_dir: str
    testscripts_cache: str

    # Retention (already parsed to seconds by argparse type=parse_retention)
    report_retention: Optional[int]

    # Timing
    timeout: int

    # Resource limits
    memory_limit: str

    # Behaviour flags
    debug: bool
    shell: bool
    headed: bool
    browser: str

    # Reporting
    report_url: Optional[str]
    href_target: str

    # Registry credentials
    registry_username: Optional[str]
    registry_password: Optional[str]

    # S3 credentials / config
    s3_endpoint: Optional[str]
    aws_access_key_id: Optional[str]
    aws_secret_access_key: Optional[str]
    s3_bucket: Optional[str]
    s3_report_bucket: Optional[str]
    s3_report_path: Optional[str]
    s3_report_url: Optional[str]

    # Loki credentials / config
    loki_endpoint: Optional[str]
    loki_user: Optional[str]
    loki_password: Optional[str]
    loki_proxy: Optional[str]

    # Naemon state
    current_status: Optional[str]


@dataclass(frozen=True)
class RunContext:
    """Immutable per-run state derived from RunConfig plus environment.

    Constructed once after RunConfig and after early validation (container
    env check, headed pre-flight). Holds RunConfig for access to all
    CLI arguments. Contains no mutable state.
    """
    # Identity (derived)
    hostname: str
    servicedescription: str
    testname: str
    testident: str
    container_name: str

    # Timing
    start_time: float
    started_str: str
    timeout_deadline: float

    # Paths (fully resolved — all template vars expanded)
    result_dir: str
    omd_root: str
    pid_file: str

    # All CLI arguments
    config: RunConfig


# ---------------------------------------------------------------------------
# TESTNAME derivation and path template resolution (T005)
# ---------------------------------------------------------------------------

def derive_testname(hostname: str, servicedescription: str) -> str:
    """Derive TESTNAME from hostname and service description.

    TESTNAME is symbolic, not a path. Used as container name and PID identity.
    """
    return f"{hostname}/{servicedescription}"


def derive_testident(hostname: str, servicedescription: str) -> str:
    """Derive URL-encoded TESTIDENT for PID files and archive names."""
    return urllib.parse.quote(f"{hostname}__{servicedescription}", safe="")


def resolve_path_template(template: str, ctx: "RunContext") -> str:
    """Replace %h, %s, and %t template variables in path strings."""
    result = template.replace("%h", ctx.hostname).replace("%s", ctx.servicedescription)
    if ctx.started_str:
        result = result.replace("%t", ctx.started_str)
    return result


def sanitize_container_name(testname: str) -> str:
    """Sanitize testname for use as Podman container name."""
    return re.sub(r"[^a-zA-Z0-9_.-]+", "_", testname.replace(" ", "_"))


# ---------------------------------------------------------------------------
# PID file concurrency control (T015)
# ---------------------------------------------------------------------------

def is_process_running(pid: int) -> bool:
    """Check if a process with given PID is running."""
    try:
        os.kill(pid, 0)
    except OSError:
        return False
    return True


def check_pid_file(pid_file_path: str) -> Optional[int]:
    """Check PID file. Returns existing PID if running, None otherwise."""
    if not os.path.exists(pid_file_path):
        return None
    try:
        with open(pid_file_path, "r") as f:
            existing_pid = int(f.read().strip())
        if is_process_running(existing_pid):
            return existing_pid
        else:
            logger.debug(f"Found stale PID {existing_pid}. Overwriting.")
            return None
    except (ValueError, IOError) as e:
        logger.warning(f"Could not read PID file {pid_file_path}: {e}")
        return None


def write_pid_file(pid_file_path: str) -> None:
    """Write current PID to file."""
    with open(pid_file_path, "w") as f:
        f.write(str(os.getpid()))


def remove_pid_file(pid_file_path: str) -> None:
    """Remove PID file if it exists."""
    try:
        if os.path.exists(pid_file_path):
            os.remove(pid_file_path)
    except OSError as e:
        logger.warning(f"Could not remove PID file {pid_file_path}: {e}")


