def container_cleanup(container_bin: str, container_name: str) -> None:
    """Remove stale container with same name via podman rm -f."""
    cmd = [container_bin, "rm", "--force", "--filter", f"name=^{container_name}$"]
    subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, encoding="utf-8")


# ---------------------------------------------------------------------------
# Headed mode (display forwarding for debug)
# ---------------------------------------------------------------------------

def detect_display_server() -> str:
    """Detect whether the session uses Wayland or X11.

    Returns 'wayland' if WAYLAND_DISPLAY is set and the socket exists,
    'x11' if DISPLAY is set and reachable, or '' if neither.

    X11 DISPLAY formats:
      :0          — local display (Unix socket /tmp/.X11-unix/X0)
      :10.0       — local display with screen number
      localhost:10.0 — SSH-forwarded (TCP, no local socket)
      hostname:0  — remote display (TCP)
    """
    wayland_display = os.environ.get("WAYLAND_DISPLAY", "")
    xdg_runtime = os.environ.get("XDG_RUNTIME_DIR", "")
    if wayland_display and xdg_runtime:
        socket_path = os.path.join(xdg_runtime, wayland_display)
        if os.path.exists(socket_path):
            return "wayland"

    display = os.environ.get("DISPLAY", "")
    if display:
        # Extract display number from :N or hostname:N (optional .screen suffix)
        match = re.match(r"(?:.*?)?:(\d+)", display)
        if match:
            display_num = match.group(1)
            socket_path = f"/tmp/.X11-unix/X{display_num}"
            if os.path.exists(socket_path):
                # Local Unix socket (e.g. :0, :1)
                return "x11"
            if ":" in display and not display.startswith(":"):
                # Remote/SSH-forwarded display (e.g. localhost:10.0) — no
                # local socket expected; SSH handles the TCP forwarding.
                return "x11"

    return ""


def is_local_x11() -> bool:
    """True when DISPLAY points to a local Unix socket (e.g. :0), not SSH/TCP."""
    display = os.environ.get("DISPLAY", "")
    return display.startswith(":")


def validate_headed_mode() -> Optional[str]:
    """Pre-flight checks for --headed mode.

    Returns error message string or None if everything is OK.
    """
    server = detect_display_server()
    if server == "wayland":
        return None
    if server == "x11":
        # xhost is only needed for local Unix-socket displays.
        # SSH-forwarded displays (localhost:10.0) use .Xauthority instead.
        if is_local_x11() and not shutil.which("xhost"):
            return "--headed requires xhost to be installed (X11 mode)"
        return None
    return "--headed requires WAYLAND_DISPLAY or DISPLAY to be set"


def setup_x11_access() -> None:
    """Run xhost +local: to allow container X11 connections.

    Only relevant for local Unix-socket displays.  SSH-forwarded displays
    use .Xauthority for authentication, so xhost is not needed.
    """
    if is_local_x11() and shutil.which("xhost"):
        subprocess.run(["xhost", "+local:"],
                       stdout=subprocess.PIPE, stderr=subprocess.PIPE)


# ---------------------------------------------------------------------------
# Report cleanup (009-report-management)
# ---------------------------------------------------------------------------

@dataclass
class CleanupResult:
    deleted: List[str] = field(default_factory=list)
    skipped: List[str] = field(default_factory=list)
    failed: List[Tuple[str, Exception]] = field(default_factory=list)


class ReportCleanupPlugin(Protocol):
    def list_candidates(
        self,
        parent_dir: str,
        current_run_dir: str,
        retention_seconds: int,
    ) -> List[dict]: ...

    def delete_candidate(self, candidate: dict) -> None: ...


class LocalCleanup:
    """Local filesystem implementation of ReportCleanupPlugin."""

    def list_candidates(
        self,
        parent_dir: str,
        current_run_dir: str,
        retention_seconds: int,
    ) -> List[dict]:
        """Return eligible run directories sorted oldest-first."""
        candidates = []
        now = time.time()
        try:
            with os.scandir(parent_dir) as it:
                for entry in it:
                    if not entry.is_dir():
                        continue
                    if not re.fullmatch(r"\d+", entry.name):
                        continue
                    meta_path = os.path.join(entry.path, "test-meta.json")
                    if not os.path.exists(meta_path):
                        continue
                    started = int(entry.name)
                    if now - started <= retention_seconds:
                        continue
                    if entry.path == current_run_dir:
                        continue
                    candidates.append({"path": entry.path, "started": started})
        except OSError as e:
            logger.warning(f"LocalCleanup.list_candidates failed to scan {parent_dir}: {e}")
        candidates.sort(key=lambda c: c["started"])
        return candidates

    def delete_candidate(self, candidate: dict) -> None:
        """Delete a single candidate run directory."""
        shutil.rmtree(candidate["path"])


def parse_retention(value: str) -> int:
    """Parse a retention string like '24h' into seconds.

    Raises ArgumentTypeError on invalid input.
    """
    if not value.endswith("h"):
        raise ArgumentTypeError(
            f"retention value must end with 'h' (e.g. 24h), got: {value!r}"
        )
    prefix = value[:-1]
    try:
        hours = int(prefix)
    except ValueError:
        raise ArgumentTypeError(
            f"retention value must be a positive integer followed by 'h', got: {value!r}"
        )
    if hours < 1:
        raise ArgumentTypeError(
            f"retention must be >= 1h, got: {value!r}"
        )
    return hours * 3600


def run_cleanup(plugin: ReportCleanupPlugin, ctx: RunContext) -> CleanupResult:
    """Delete eligible old run directories oldest-first within the timeout budget."""
    parent_dir = os.path.dirname(ctx.result_dir)
    current_run_dir = ctx.result_dir
    retention_seconds = ctx.config.report_retention
    safety_margin = 10.0
    result = CleanupResult()
    if time.time() > ctx.timeout_deadline - safety_margin:
        logger.debug("run_cleanup: skipping, insufficient time remaining before deadline")
        return result
    candidates = plugin.list_candidates(parent_dir, current_run_dir, retention_seconds)
    for candidate in candidates:
        if time.time() > ctx.timeout_deadline - safety_margin:
            result.skipped.append(candidate["path"])
            continue
        try:
            plugin.delete_candidate(candidate)
            result.deleted.append(candidate["path"])
        except Exception as exc:
            result.failed.append((candidate["path"], exc))
            logger.debug(f"run_cleanup: failed to delete {candidate['path']}: {exc}")
    return result


# ---------------------------------------------------------------------------
# Container environment variable assembly (T007)
# ---------------------------------------------------------------------------

def build_env_vars(ctx: RunContext) -> Dict[str, str]:
    """Build container environment variable dict from run context."""
    env = {
        "TEST_SOURCE": ctx.config.test_source,
        "RESULT_DEST": ctx.config.result_dest,
        "LOGGING": ctx.config.logging,
        "NAGIOS_HOSTNAME": ctx.hostname,
        "NAGIOS_SERVICEDESC": ctx.servicedescription,
        "PWTIMEOUT": str(ctx.config.timeout),
        "PROBE_LOCATION": ctx.config.probe_location,
        "TESTIDENT": ctx.testident,
        "TERM": "dumb",
        "FORCE_COLOR": "false",
        "CEP_STARTED": ctx.started_str,
    }

    if ctx.config.debug:
        env["DEBUG"] = "1"

    if ctx.config.headed:
        env["HEADED"] = "1"

    env["BROWSER"] = ctx.config.browser

    # Spectate mode: pass through slow-motion and highlight timing
    for passthrough in ("CEP_VISION_HIGHLIGHT_MS", "CEP_SLOW_MO"):
        val = os.environ.get(passthrough)
        if val:
            env[passthrough] = val

    # S3 credentials (when S3 plugins active)
    if ctx.config.s3_endpoint:
        env["S3_ENDPOINT"] = ctx.config.s3_endpoint
    if ctx.config.aws_access_key_id:
        env["AWS_ACCESS_KEY_ID"] = ctx.config.aws_access_key_id
    if ctx.config.aws_secret_access_key:
        env["AWS_SECRET_ACCESS_KEY"] = ctx.config.aws_secret_access_key
    if ctx.config.s3_bucket:
        env["S3_BUCKET"] = ctx.config.s3_bucket
    if ctx.config.s3_report_bucket:
        env["S3_REPORT_BUCKET"] = ctx.config.s3_report_bucket
    if ctx.config.s3_report_path:
        env["REPORT_PATH"] = ctx.config.s3_report_path

    # Loki credentials (when logging=loki)
    if ctx.config.loki_endpoint:
        env["LOKI_ENDPOINT"] = ctx.config.loki_endpoint
    if ctx.config.loki_user:
        env["LOKI_USER"] = ctx.config.loki_user
    if ctx.config.loki_password:
        env["LOKI_PASSWORD"] = ctx.config.loki_password
    if ctx.config.loki_proxy:
        env["LOKI_PROXY"] = ctx.config.loki_proxy

    # Naemon state info
    if ctx.config.current_status:
        env["NAGIOS_CURRENT_STATUS"] = ctx.config.current_status

    return env


# ---------------------------------------------------------------------------
# Podman command building (T008)
# ---------------------------------------------------------------------------

def build_podman_command(ctx: RunContext, container_bin: str,
                         env_vars: Dict[str, str]) -> List[str]:
    """Build complete podman run command."""
    cgroup_parent = ctx.container_name.replace("-", "_") + ".slice"

    cmd = [
        container_bin,
        "run",
        "--rm",
        "--interactive",
        "--log-driver=none",
        "--hostname", os.uname().nodename,
        "--name", ctx.container_name,
        "--cgroup-parent", cgroup_parent,
    ]

    # Resource limits (FR-006: CPU hardcoded at 2)
    cmd.extend(["--cpus", str(DEFAULT_CPU_COUNT)])
    memory_limit = ctx.config.memory_limit if ctx.config.memory_limit else DEFAULT_MEMORY_LIMIT
    if memory_limit and memory_limit[-1] not in "bkmg":
        memory_limit += "g"
    cmd.extend(["--memory", memory_limit])

    # Environment variables
    for key, value in env_vars.items():
        cmd.extend(["--env", f"{key}={value}"])

    # Conditional volume mounts
    test_dir = resolve_path_template(ctx.config.test_dir, ctx)

    if ctx.config.test_source == "local":
        cmd.extend(["--volume", f"{os.path.abspath(test_dir)}:/home/pwuser/tests:ro,z"])
    cmd.extend(["--volume", f"{os.path.abspath(ctx.result_dir)}:/home/pwuser/results:rw,z"])
    if ctx.config.test_source == "s3":
        cache_dir = ctx.config.testscripts_cache
        cmd.extend(["--volume", f"{os.path.abspath(cache_dir)}:/home/pwuser/testscripts-cache:rw,z"])

    # Headed mode: display forwarding for debug
    if ctx.config.headed:
        cmd.extend([
            f"--userns=keep-id:uid={CONTAINER_UID},gid={CONTAINER_GID}",
            "--security-opt", "label=disable",
            "--ipc=host",
        ])
        if detect_display_server() == "wayland":
            wayland_display = os.environ["WAYLAND_DISPLAY"]
            xdg_runtime = os.environ["XDG_RUNTIME_DIR"]
            host_socket = os.path.join(xdg_runtime, wayland_display)
            container_runtime = f"/run/user/{CONTAINER_UID}"
            cmd.extend([
                "--volume", f"{host_socket}:{container_runtime}/{wayland_display}:ro",
                "--env", f"WAYLAND_DISPLAY={wayland_display}",
                "--env", f"XDG_RUNTIME_DIR={container_runtime}",
            ])
        else:
            display = os.environ.get("DISPLAY", ":0")
            xauthority = os.path.expanduser("~/.Xauthority")
            if display.startswith(":"):
                # Local X11 — forward via Unix socket
                cmd.extend([
                    "--volume", "/tmp/.X11-unix:/tmp/.X11-unix:ro",
                    "--env", f"DISPLAY={display}",
                ])
            else:
                # Remote/SSH-forwarded X11 (e.g. localhost:10.0) — the
                # display is TCP-based.  Use host networking so the
                # container can reach the SSH-forwarded port on loopback.
                cmd.extend([
                    "--network=host",
                    "--env", f"DISPLAY={display}",
                ])
            if os.path.exists(xauthority):
                cmd.extend([
                    "--volume", f"{xauthority}:/tmp/.Xauthority:ro",
                    "--env", "XAUTHORITY=/tmp/.Xauthority",
                ])

    # Shell mode: replace entrypoint with bash
    if ctx.config.shell:
        cmd.extend(["--tty", "--interactive", "--entrypoint", "bash"])

    cmd.append(ctx.config.image)
    return cmd


# ---------------------------------------------------------------------------
# Container execution (T017)
# ---------------------------------------------------------------------------

def execute_container(cmd: List[str], shell_mode: bool = False) -> Tuple[bytes, bytes, int]:
    """Execute podman run and return (stdout, stderr, returncode)."""
    logger.debug("running command: %s", " ".join(cmd))
    if shell_mode:
        proc = subprocess.run(cmd)
        return b"", b"", proc.returncode
    else:
        proc = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        return proc.stdout, proc.stderr, proc.returncode


# ---------------------------------------------------------------------------
# Registry auth retry (T018)
# ---------------------------------------------------------------------------

def retry_with_auth(container_bin: str, cmd: List[str], image: str,
                    username: str, password: str) -> Tuple[bytes, bytes, int]:
    """Attempt podman login and retry the container command."""
    if "/" not in image:
        return b"", b"", EXIT_CRITICAL

    registry = image.split("/")[0]
    login_cmd = [container_bin, "login", "-u", username, "-p", password, registry]
    logger.debug("login as %s at registry %s", username, registry)
    login = subprocess.run(login_cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)

    if login.returncode == 0:
        logger.debug("re-running command: %s", " ".join(cmd))
        proc = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        return proc.stdout, proc.stderr, proc.returncode
    else:
        logger.debug("login failed")
        return b"", b"", EXIT_CRITICAL


