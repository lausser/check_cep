# ---------------------------------------------------------------------------
# Output sanitization utilities
# ---------------------------------------------------------------------------

def remove_html_entities(line: str) -> str:
    """Escape HTML special characters for safe Nagios output."""
    return (
        line.replace("&", "&amp;")
        .replace("<", "&lt;")
        .replace(">", "&gt;")
        .replace('"', "&quot;")
    )


def remove_ansi_escapes(line: bytes) -> str:
    """Remove ANSI escape codes from byte string, decode to ASCII."""
    ansi_escape = re.compile(r"(?:\x1B[@-_]|[\x80-\x9F])[0-?]*[ -/]*[@-~]")
    decoded = line.decode("ascii", "ignore")
    cleaned = ansi_escape.sub("", decoded)
    cleaned = re.sub(r"(?imu)^\s*\n", "", cleaned)
    return cleaned.replace("|", "")


def remove_invalid_surrogates(text: str) -> str:
    """Remove invalid Unicode surrogates."""
    return "".join(char for char in text if unicodedata.category(char) != "Cn")


def remove_variation_selectors(text: str) -> str:
    """Remove invisible variation selectors (U+FE0E, U+FE0F)."""
    return re.sub(r"[\uFE0E\uFE0F]", "", text)


def replace_emojis(line: str) -> str:
    """Replace emoji characters with ASCII equivalents."""
    emoji_replacements = {
        "\U0001f602": ":-D",
        "\U0001f60a": ":-)",
        "\U0001f622": ":'(",
        "\U0001f60e": "B-)",
        "\U00002764": "<3",
        "\U0001f50d": ":emoji:",
    }
    line = unicodedata.normalize("NFC", line)
    line = remove_invalid_surrogates(line)
    line = remove_variation_selectors(line)
    emoji_pattern = re.compile(
        r"[\U0001f600-\U0001f64f\U0001f300-\U0001f5ff"
        r"\U0001f680-\U0001f6ff\U0001f700-\U0001f77f"
        r"\U0001f900-\U0001faff]+",
        flags=re.UNICODE,
    )

    def emoji_replacer(match):
        return emoji_replacements.get(match.group(0), ":emoji:")

    return emoji_pattern.sub(emoji_replacer, line).encode("utf-8", errors="replace").decode("utf-8")


def sanitize_output(raw: bytes) -> str:
    """Full sanitization pipeline for container output."""
    text = remove_ansi_escapes(raw)
    text = replace_emojis(text)
    text = remove_html_entities(text)
    return text


def truncate_playwright_diff(msg: str) -> str:
    """Remove the 'Received string' block from Playwright assertion diffs.

    When toContainText() fails against a large locator such as locator('body'),
    Playwright dumps the entire element text as the received value — potentially
    thousands of lines.  We keep the header lines and the expected (-) lines
    so the failure reason is clear, but drop all received (+) lines.

    Messages that do not match the Playwright diff format are returned unchanged.
    """
    lines = msg.splitlines()
    received_idx = None
    for i, line in enumerate(lines):
        if re.search(r'\+ Received string\s+\+\s+\d+', line):
            received_idx = i
            break
    if received_idx is None:
        return msg
    kept = lines[:received_idx + 1]
    expected_lines = [l for l in lines[received_idx + 1:] if l.startswith('- ')]
    if expected_lines:
        kept.append('')
        kept.extend(expected_lines)
    kept.append('[received string omitted]')
    return '\n'.join(kept)


# ---------------------------------------------------------------------------
# Nagios output formatting (T006)
# ---------------------------------------------------------------------------

def camelcase(label: str) -> str:
    """Convert space-separated label to CamelCase."""
    return "".join(word.capitalize() for word in label.strip().split())


def format_perfdata(perfdata_list: List[Dict[str, Any]]) -> str:
    """Format perfdata list as Nagios perfdata string.

    All labels are single-quoted per the Nagios output contract.
    """
    parts = []
    for pd in perfdata_list:
        label = pd["label"]
        value = pd["value"]
        unit = pd.get("unit", "")
        parts.append(f"'{label}'={value}{unit}")
    return " ".join(parts)


def nagios_exit(status: str, message: str, perfdata_str: str = "", long_output: str = "") -> int:
    """Print Nagios status line and return exit code.

    Args:
        status: One of OK, WARNING, CRITICAL, UNKNOWN
        message: Human-readable summary
        perfdata_str: Pre-formatted perfdata string
        long_output: Multi-line details (lines 2+)

    Returns:
        Nagios exit code integer
    """
    code_map = {"OK": EXIT_OK, "WARNING": EXIT_WARNING, "CRITICAL": EXIT_CRITICAL, "UNKNOWN": EXIT_UNKNOWN}
    line1 = f"{status} - {message}"
    if perfdata_str:
        line1 += f" | {perfdata_str}"
    print(line1)
    if long_output:
        print(long_output)
    return code_map.get(status, EXIT_UNKNOWN)


