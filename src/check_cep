# Exit codes
EXIT_OK = 0
EXIT_WARNING = 1
EXIT_CRITICAL = 2
EXIT_UNKNOWN = 3
EXIT_AUTH_REQUIRED = 125  # Podman authentication failure

# File permissions
PERM_WORLD_RWX = 0o777

# Log rotation
LOG_MAX_BYTES = 1_000_000
LOG_BACKUP_COUNT = 3

# Default resource limits
DEFAULT_MEMORY_LIMIT = "2g"
DEFAULT_CPU_COUNT = 2  # Hardcoded intentional (FR-006)

