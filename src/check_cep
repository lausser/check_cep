def parse_steps_json(json_path: str) -> Optional[dict]:
    """Parse steps.json file. Returns parsed dict or None."""
    if not os.path.exists(json_path):
        return None
    try:
        with open(json_path, "r", encoding="utf-8") as f:
            return json.load(f)
    except (json.JSONDecodeError, IOError) as e:
        logger.warning(f"Could not parse {json_path}: {e}")
        return None


def extract_perfdata_from_steps(subjson: dict, level: int = 0, prefix: str = "") -> List[Dict[str, Any]]:
    """Recursively extract perfdata from steps.json structure.

    Returns list of perfdata dicts with label, value, unit.
    """
    perfdata = []

    for suite in subjson.get("suites", []):
        if level == 0 and len(subjson["suites"]) > 1:
            new_prefix = camelcase(os.path.basename(suite["title"]).replace(".test.ts", ""))
        elif level == 0:
            new_prefix = prefix
        else:
            new_prefix = prefix + camelcase(suite["title"])
        perfdata.extend(extract_perfdata_from_steps(suite, level + 1, new_prefix))

    for spec in subjson.get("specs", []):
        new_prefix = prefix + camelcase(spec["title"])
        perfdata.extend(extract_perfdata_from_steps(spec, level + 1, new_prefix))

    for test in subjson.get("tests", []):
        if len(subjson["tests"]) > 1:
            new_prefix = prefix + camelcase(test["projectName"])
        else:
            new_prefix = prefix
        if len(test["results"]) > 0:
            perfdata.extend(extract_perfdata_from_steps(test["results"][0], level + 1, new_prefix))
            if "duration" in test["results"][0]:
                perfdata.append({"label": new_prefix + "_td", "value": test["results"][0]["duration"], "unit": "ms"})

        # Annotation-based perfdata
        for annotation in test.get("annotations", []):
            if "type" in annotation and annotation["type"].startswith("perfdata_"):
                m = re.match(r"([\d]+\.*[\d]*)([a-z%]*)", annotation.get("description", ""))
                if m:
                    suffix = "_cd" if m[2] and m[2].endswith("s") else "_cm"
                    perfdata.append({
                        "label": prefix + camelcase(annotation["type"].replace("perfdata_", "") + suffix),
                        "value": m[1],
                        "unit": m[2],
                    })

    for step in subjson.get("steps", []):
        new_prefix = prefix + camelcase(step["title"])
        perfdata.append({"label": new_prefix + "_sd", "value": step["duration"], "unit": "ms"})
        perfdata.extend(extract_perfdata_from_steps(step, level + 1, new_prefix))

    return perfdata


def extract_output_from_steps(subjson: dict, level: int = 0, prefix: str = "", debug: bool = False) -> Tuple[str, bool]:
    """Recursively extract stdout/stderr/errors from steps.json.

    Returns (output_text, has_stderr).
    """
    output = ""
    has_stderr = False

    for suite in subjson.get("suites", []):
        if level == 0 and len(subjson["suites"]) > 1:
            new_prefix = os.path.basename(suite["title"]).replace(".test.ts", "")
        elif level == 0:
            new_prefix = prefix
        else:
            new_prefix = prefix + " - " + suite["title"]
        sub_output, sub_stderr = extract_output_from_steps(suite, level + 1, new_prefix, debug)
        output += sub_output
        has_stderr = has_stderr or sub_stderr

    for spec in subjson.get("specs", []):
        sub_output, sub_stderr = extract_output_from_steps(spec, level + 1, prefix + " - " + spec["title"], debug)
        output += sub_output
        has_stderr = has_stderr or sub_stderr

    for test in subjson.get("tests", []):
        if len(subjson["tests"]) > 1:
            new_prefix = prefix + " - " + test["projectName"]
        else:
            new_prefix = prefix
        if len(test["results"]) > 0:
            sub_output, sub_stderr = extract_output_from_steps(test["results"][0], level + 1, new_prefix, debug)
            output += sub_output
            has_stderr = has_stderr or sub_stderr

    for index, stdout_entry in enumerate(subjson.get("stdout", [])):
        if index == 0:
            output += "\n__Stdout " + prefix + "__"
        text = stdout_entry.get("text", "")
        if text.startswith("NagiosPerfData:"):
            continue
        if text.lstrip().startswith("[CEPDBG]") and not debug:
            continue
        output += "\n" + text.rstrip()

    stderr_lines = []
    for stderr_entry in subjson.get("stderr", []):
        text = stderr_entry.get("text", "").rstrip()
        stderr_lines.append(text)
    if stderr_lines:
        output += "\n__Stderr " + prefix + "__"
        for line in stderr_lines:
            output += "\n" + line
        has_stderr = True

    for index, error in enumerate(subjson.get("errors", [])):
        if index == 0:
            output += "\n__Errors " + prefix + "__"
        msg = error.get("message", "")
        sanitized = sanitize_output(replace_emojis(msg).encode("utf-8"))
        output += "\n" + truncate_playwright_diff(sanitized).rstrip()

    return output, has_stderr


def extract_nagios_perfdata_from_stdout(subjson: dict, level: int = 0) -> List[Dict[str, Any]]:
    """Extract NagiosPerfData: lines from stdout in steps.json."""
    perfdata = []

    for suite in subjson.get("suites", []):
        perfdata.extend(extract_nagios_perfdata_from_stdout(suite, level + 1))
    for spec in subjson.get("specs", []):
        perfdata.extend(extract_nagios_perfdata_from_stdout(spec, level + 1))
    for test in subjson.get("tests", []):
        if len(test.get("results", [])) > 0:
            perfdata.extend(extract_nagios_perfdata_from_stdout(test["results"][0], level + 1))

    for stdout_entry in subjson.get("stdout", []):
        text = stdout_entry.get("text", "")
        m = re.match(r"NagiosPerfData:\s*'(.*?)'=([\d]+\.?[\d]*)([a-z%]*)", text)
        if m:
            perfdata.append({"label": m[1], "value": m[2], "unit": m[3]})

    return perfdata


def normalize_perfdata_labels(perfdata: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    """Normalize perfdata labels: strip suffixes for display."""
    num_tests = sum(1 for pd in perfdata if pd["label"].endswith("_td"))

    if num_tests == 1:
        # Single test: simplify labels
        name_test = None
        for pd in perfdata:
            if pd["label"].endswith("_td"):
                name_test = re.sub(r"_td$", "", pd["label"])
                break
        if name_test:
            result = []
            for pd in perfdata:
                label = pd["label"]
                if label.endswith("_td"):
                    result.append({"label": "TestDuration", "value": pd["value"], "unit": pd.get("unit", "")})
                elif any(label.endswith(s) for s in ["_sd", "_cd", "_cm"]):
                    result.append({"label": label.replace(name_test, ""), "value": pd["value"], "unit": pd.get("unit", "")})
                else:
                    result.append(pd)
            perfdata = result
    else:
        # Multiple tests: expand _td to _test_duration
        perfdata = [
            {"label": re.sub(r"_td$", "_test_duration", pd["label"]), "value": pd["value"], "unit": pd.get("unit", "")}
            if pd["label"].endswith("_td") else pd
            for pd in perfdata
        ]

    # Strip remaining suffixes for final output
    result = []
    for pd in perfdata:
        label = pd["label"]
        for suffix in ["_sd", "_cd", "_cm"]:
            label = re.sub(f"{suffix}$", "", label)
        result.append({"label": label, "value": pd["value"], "unit": pd.get("unit", "")})
    return result


