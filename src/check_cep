def main() -> int:
    """Main entry point."""
    parser = build_argument_parser()
    args = parser.parse_args()

    # Capture process start time before any path resolution so %t is available
    start_time = time.time()
    started_str = str(int(start_time))

    # ---------------------------------------------------------------------------
    # Build typed CLI argument wrapper (010-run-context)
    # ---------------------------------------------------------------------------
    config = RunConfig(
        host_name=args.host_name,
        service_description=args.service_description,
        image=args.image,
        probe_location=args.probe_location,
        test_source=args.test_source,
        result_dest=args.result_dest,
        logging=args.logging,
        test_dir=args.test_dir,
        result_dir=args.result_dir,
        testscripts_cache=args.testscripts_cache,
        report_retention=args.report_retention,
        timeout=args.timeout,
        memory_limit=args.memory_limit,
        debug=args.debug,
        shell=args.shell,
        headed=args.headed,
        browser=args.browser,
        report_url=args.report_url,
        href_target=args.href_target,
        registry_username=args.registry_username,
        registry_password=args.registry_password,
        s3_endpoint=args.s3_endpoint,
        aws_access_key_id=args.aws_access_key_id,
        aws_secret_access_key=args.aws_secret_access_key,
        s3_bucket=args.s3_bucket,
        s3_report_bucket=args.s3_report_bucket,
        s3_report_path=args.s3_report_path,
        s3_report_url=args.s3_report_url,
        loki_endpoint=args.loki_endpoint,
        loki_user=args.loki_user,
        loki_password=args.loki_password,
        loki_proxy=args.loki_proxy,
        current_status=args.current_status,
    )

    # ---------------------------------------------------------------------------
    # Logging setup (T032)
    # ---------------------------------------------------------------------------
    omd_root = os.environ.get("OMD_ROOT", "")
    log_path = omd_root + "/var/log/check_cep.log"

    logger.setLevel(logging.DEBUG if config.debug else logging.CRITICAL)
    try:
        file_handler = RotatingFileHandler(log_path, maxBytes=LOG_MAX_BYTES, backupCount=LOG_BACKUP_COUNT)
        formatter = logging.Formatter("%(asctime)s - %(levelname)s - %(message)s")
        file_handler.setFormatter(formatter)
        file_handler.setLevel(logging.DEBUG if config.debug else logging.CRITICAL)
        logger.addHandler(file_handler)
    except (OSError, IOError):
        pass  # Log dir may not exist outside OMD

    if config.debug:
        console_handler = logging.StreamHandler()
        console_handler.setFormatter(logging.Formatter("%(asctime)s - %(levelname)s - %(message)s"))
        console_handler.setLevel(logging.DEBUG)
        logger.addHandler(console_handler)

    # ---------------------------------------------------------------------------
    # Detect container environment
    # ---------------------------------------------------------------------------
    containerenv = ContainerEnv()
    if not containerenv.ok:
        return nagios_exit("UNKNOWN", containerenv.failure)

    # ---------------------------------------------------------------------------
    # Browser conflict validation
    # ---------------------------------------------------------------------------
    if config.browser == "lightpanda" and config.headed:
        return nagios_exit("UNKNOWN",
                           "--headed is not supported with --browser lightpanda (headless-only browser)")

    # ---------------------------------------------------------------------------
    # Headed mode pre-flight
    # ---------------------------------------------------------------------------
    if config.headed:
        headed_error = validate_headed_mode()
        if headed_error:
            return nagios_exit("UNKNOWN", headed_error)
        if detect_display_server() == "x11":
            setup_x11_access()

    # ---------------------------------------------------------------------------
    # Build run context (010-run-context)
    # ---------------------------------------------------------------------------
    _testname = derive_testname(config.host_name, config.service_description)
    _testident = derive_testident(config.host_name, config.service_description)
    _result_dir = config.result_dir.replace("%h", config.host_name).replace("%s", config.service_description)
    if started_str:
        _result_dir = _result_dir.replace("%t", started_str)
    ctx = RunContext(
        hostname=config.host_name,
        servicedescription=config.service_description,
        testname=_testname,
        testident=_testident,
        container_name=sanitize_container_name(_testname),
        start_time=start_time,
        started_str=started_str,
        timeout_deadline=start_time + config.timeout,
        result_dir=_result_dir,
        omd_root=omd_root,
        pid_file=os.path.join(omd_root or "/tmp", "var", "tmp", f"check_cep.{_testident}.pid"),
        config=config,
    )
    logger.debug("RunContext: %s", ctx)

    # ---------------------------------------------------------------------------
    # PID file concurrency check (T015)
    # ---------------------------------------------------------------------------
    os.makedirs(ctx.result_dir, mode=PERM_WORLD_RWX, exist_ok=True)
    os.chmod(ctx.result_dir, PERM_WORLD_RWX)
    # Files and subdirs from previous runs are owned by the site user.
    # The container's pwuser maps to a sub-uid of the site user and cannot
    # overwrite them — chmod everything in the result tree open.
    for dirpath, dirnames, filenames in os.walk(ctx.result_dir):
        for d in dirnames:
            try:
                os.chmod(os.path.join(dirpath, d), PERM_WORLD_RWX)
            except OSError:
                pass
        for f in filenames:
            try:
                os.chmod(os.path.join(dirpath, f), PERM_WORLD_RWX)
            except OSError:
                pass

    # S3 testscripts cache needs the same world-writable treatment so the
    # container's pwuser (mapped to a sub-uid) can create subdirs.
    if ctx.config.test_source == "s3":
        cache_dir = ctx.config.testscripts_cache
        os.makedirs(cache_dir, mode=PERM_WORLD_RWX, exist_ok=True)
        os.chmod(cache_dir, PERM_WORLD_RWX)
        for dirpath, dirnames, filenames in os.walk(cache_dir):
            for d in dirnames:
                try:
                    os.chmod(os.path.join(dirpath, d), PERM_WORLD_RWX)
                except OSError:
                    pass

    os.makedirs(os.path.dirname(ctx.pid_file), mode=PERM_WORLD_RWX, exist_ok=True)
    existing_pid = check_pid_file(ctx.pid_file)
    if existing_pid is not None:
        return nagios_exit("UNKNOWN", f"test {ctx.servicedescription} duplicate, "
                          f"process with PID {existing_pid} is already running")

    write_pid_file(ctx.pid_file)

    # ---------------------------------------------------------------------------
    # Container cleanup (T016)
    # ---------------------------------------------------------------------------
    container_cleanup(containerenv.container_bin, ctx.container_name)

    # ---------------------------------------------------------------------------
    # Build and execute container (T007, T008, T017)
    # ---------------------------------------------------------------------------
    env_vars = build_env_vars(ctx)
    cmd = build_podman_command(ctx, containerenv.container_bin, env_vars)

    # Start cgroup poller (T027)
    cgroup_poller = None
    if containerenv.has_cgroups2:
        cgroup_poller = CgroupPoller(ctx.container_name, DEFAULT_CPU_COUNT)
        cgroup_poller.start()

    container_start_time = time.time()
    stdout, stderr, returncode = execute_container(cmd, shell_mode=ctx.config.shell)

    # Stop cgroup poller
    if cgroup_poller:
        cgroup_poller.stop()

    wall_duration = int(time.time() - container_start_time)

    # Cleanup PID file
    remove_pid_file(ctx.pid_file)

    # Shell mode: just exit
    if ctx.config.shell:
        return returncode

    # ---------------------------------------------------------------------------
    # Auth retry (T018)
    # ---------------------------------------------------------------------------
    if (returncode == EXIT_AUTH_REQUIRED
            and b"Authentication is required" in stderr
            and ctx.config.registry_username):
        stdout, stderr, returncode = retry_with_auth(
            containerenv.container_bin, cmd, ctx.config.image,
            ctx.config.registry_username, ctx.config.registry_password)
    elif returncode == EXIT_AUTH_REQUIRED:
        returncode = EXIT_CRITICAL

    # ---------------------------------------------------------------------------
    # Sanitize container output (T034)
    # ---------------------------------------------------------------------------
    stdout_str = sanitize_output(stdout)
    stderr_str = sanitize_output(stderr)

    # ---------------------------------------------------------------------------
    # Parse steps.json (T019)
    # ---------------------------------------------------------------------------
    perfdata = []
    container_output = ""
    has_stderr_in_steps = False

    steps_json_path = os.path.join(ctx.result_dir, "steps.json")
    steps_data = parse_steps_json(steps_json_path)

    if steps_data is not None:
        perfdata.extend(extract_perfdata_from_steps(steps_data))
        perfdata.extend(extract_nagios_perfdata_from_stdout(steps_data))
        container_output, has_stderr_in_steps = extract_output_from_steps(steps_data, debug=ctx.config.debug)
    else:
        container_output = stdout_str
        if stderr_str:
            container_output += "\n" + stderr_str

    container_output = container_output.strip()
    if not container_output:
        container_output = "NO CONTAINER OUTPUT"

    # Extract Loki errors from stdout
    loki_errors = re.findall(r"LOKIERROR \[\[\[(.*?)\]\]\]", stdout_str)
    for loki_err in loki_errors:
        container_output += "\n" + loki_err

    # ---------------------------------------------------------------------------
    # Add wall-clock duration perfdata
    # ---------------------------------------------------------------------------
    perfdata.append({"label": "duration", "value": wall_duration, "unit": "s"})

    # ---------------------------------------------------------------------------
    # Add cgroup metrics perfdata (T030)
    # ---------------------------------------------------------------------------
    oom_killed = False
    if cgroup_poller:
        metrics = cgroup_poller.get_metrics()
        perfdata.append({"label": "podman_metric_collection_failed", "value": 1 if metrics["collection_failed"] else 0})

        if metrics["sample_count"] > 0:
            perfdata.append({"label": "podman_cpu_usage", "value": f"{metrics['cpu_usage_sec']:.2f}", "unit": "s"})
            perfdata.append({"label": "podman_peak_cpu", "value": f"{metrics['peak_cpu_pct']:.1f}", "unit": "%"})
            perfdata.append({"label": "podman_memory_current", "value": metrics["memory_current"], "unit": "B"})
            perfdata.append({"label": "podman_memory_peak", "value": metrics["memory_peak"], "unit": "B"})
            perfdata.append({"label": "podman_io_bytes_read", "value": metrics["io_bytes_read"], "unit": "B"})
            perfdata.append({"label": "podman_io_bytes_write", "value": metrics["io_bytes_write"], "unit": "B"})

            oom_kill_val = 1 if metrics["oom_kill"] > 0 else 0
            perfdata.append({"label": "podman_oom_killed", "value": oom_kill_val})
            if oom_kill_val:
                oom_killed = True
                container_output = "OOM_KILLED: container was terminated by out-of-memory killer"

        if metrics["collection_failed"]:
            errors = metrics.get("collection_errors", [])
            if errors:
                container_output += "\ncgroup metrics: " + "; ".join(errors)

    # ---------------------------------------------------------------------------
    # Normalize and format perfdata
    # ---------------------------------------------------------------------------
    perfdata = normalize_perfdata_labels(perfdata)
    perfdata_str = format_perfdata(perfdata)

    # ---------------------------------------------------------------------------
    # Exit code determination chain (T020)
    # ---------------------------------------------------------------------------
    timed_out = check_timeout(stdout_str, stderr_str)
    s3_failed = check_s3_upload_failure(stdout_str, stderr_str)
    duplicate = check_duplicate_container(stderr_str)

    # ---------------------------------------------------------------------------
    # Report cleanup (US2, US3 — 009-report-management)
    # ---------------------------------------------------------------------------
    if ctx.config.report_retention is not None and "%t" in ctx.config.result_dir:
        cleanup_plugin = LocalCleanup()
        cleanup_result = run_cleanup(cleanup_plugin, ctx)
        logger.debug(
            f"Cleanup: deleted={cleanup_result.deleted}, "
            f"skipped={cleanup_result.skipped}, "
            f"failed={[(p, str(e)) for p, e in cleanup_result.failed]}"
        )

    # Read test-meta.json for started timestamp (for report URL)
    test_meta = {}
    meta_path = os.path.join(ctx.result_dir, "test-meta.json")
    if os.path.exists(meta_path):
        try:
            with open(meta_path, "r") as f:
                test_meta = json.load(f)
        except (json.JSONDecodeError, IOError):
            pass

    # Build report annotation (T024)
    annotation = ""
    if ctx.config.report_url:
        timestamp = test_meta.get("started", ctx.started_str)
        resolved_url = resolve_report_url(
            ctx.config.report_url, ctx,
            ctx.config.probe_location, ctx.config.s3_report_bucket or "", timestamp)
        annotation = f' <a href="{urllib.parse.quote(resolved_url, safe=":/?&=")}" target="{ctx.config.href_target}">Report</a>'

    # Exit code priority chain (T020, T031)
    if oom_killed:
        exit_code = nagios_exit("CRITICAL", f"test {ctx.servicedescription} OOM killed{annotation}",
                               perfdata_str, container_output)
    elif timed_out:
        exit_code = nagios_exit("CRITICAL", f"test {ctx.servicedescription} timed out{annotation}",
                               perfdata_str, container_output)
    elif returncode != 0 and not duplicate:
        exit_code = nagios_exit("CRITICAL", f"test {ctx.servicedescription} failed{annotation}",
                               perfdata_str, container_output)
    elif has_stderr_in_steps and returncode == 0:
        exit_code = nagios_exit("WARNING", f"test {ctx.servicedescription} succeeded{annotation}",
                               perfdata_str, container_output)
    elif duplicate:
        exit_code = nagios_exit("UNKNOWN",
                               f"test {ctx.servicedescription} duplicate{annotation}, running on host {os.uname()[1]}",
                               perfdata_str, container_output)
    else:
        exit_code = nagios_exit("OK", f"test {ctx.servicedescription} succeeded{annotation}",
                               perfdata_str, container_output)

    # S3 failure appended as warning text (doesn't change exit code)
    if s3_failed:
        print("REPORT UPLOAD TO S3 FAILED")

    # Retention warning (FR-017): --report-retention without %t in --result-dir
    if ctx.config.report_retention is not None and "%t" not in ctx.config.result_dir:
        print("WARNING: --report-retention has no effect without %t in --result-dir")

    return exit_code


if __name__ == "__main__":
    sys.exit(main())
