def build_argument_parser() -> ArgumentParser:
    """Build CLI argument parser with all 26+ arguments from data-model.md."""
    parser = ArgumentParser(description="CEP - Containerized E2E Playwright monitoring plugin")

    # Required arguments
    parser.add_argument("--host-name", required=True, dest="host_name",
                        help="Naemon $HOSTNAME$ macro")
    parser.add_argument("--service-description", required=True, dest="service_description",
                        help="Naemon $SERVICEDESC$ macro")
    parser.add_argument("--image", required=True,
                        help="Podman image name with tag")
